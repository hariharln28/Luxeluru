# ============================================================
# Luxeluru Backend Environment Variables
# ============================================================
# Copy this file to .env inside the server/ folder.
# NEVER commit your .env file with real credentials to Git!
# ============================================================

# Server port (default: 5000)
PORT=5000

# Node environment: 'development' or 'production'
NODE_ENV=development

# -----------------------------------------------
# DATABASE
# -----------------------------------------------
# MongoDB connection URI (optional).
# If omitted, the server automatically uses local SQLite database.
# For production, use MongoDB Atlas: https://www.mongodb.com/atlas
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/luxeluru?retryWrites=true&w=majority

# -----------------------------------------------
# SUPABASE - Required for JWT validation
# -----------------------------------------------
# Must match the VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY in frontend .env
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here

# -----------------------------------------------
# FRONTEND URL (for CORS in production)
# -----------------------------------------------
# The public URL where the frontend is deployed (e.g. Vercel/Netlify)
FRONTEND_URL=https://your-app.vercel.app
